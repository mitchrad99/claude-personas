# Copy this file to .env for local development (never commit .env).
# For production, set these in Render.com's environment variables panel.
# For automation scripts, set them as GitHub Actions secrets.

# ── Web app (Render.com) ────────────────────────────────────────────────────

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host.pooler.supabase.com:6543/postgres

# HTTP Basic Auth — app will not start without this
CRM_PASSWORD=choose-a-strong-password

# HTTP Basic Auth username (default: admin)
CRM_USERNAME=admin

# Flask session secret — generate with: openssl rand -base64 32
SECRET_KEY=replace-with-random-string

# Anthropic API key — required for Chat tab and inbox scan
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Automation scripts (GitHub Actions secrets) ─────────────────────────────

# Same PostgreSQL URL as DATABASE_URL above
SUPABASE_URL=postgresql://user:password@host.pooler.supabase.com:6543/postgres

# Base64-encoded token.json from the Gmail OAuth flow
# Generate by running: python3 crm/auth_gmail.py
GMAIL_TOKEN_JSON=base64-encoded-value-from-auth_gmail.py

# Slack Bot token — required for slack_sync.py
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Your Slack user ID — find in Slack: profile → More → Copy member ID
SLACK_USER_ID=U01ABC123

# Optional: comma-separated channel IDs to always scan
SLACK_CHANNEL_IDS=C01ABC123,C02DEF456
